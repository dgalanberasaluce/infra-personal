// Renovate configuration file
// This configuration file is used by Renovate Bot to automate dependency updates in the project
// Renovate Bot is configured to run on the self-hosted git repository (Forgejo) 
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":timezone(Europe/Madrid)", 
    ":semanticCommits"
  ],

  "includePaths": [
    "home-lab/**/*.yml",
    "home-lab/**/*.yaml"
  ],

  "prCreation": "immediate",
  "rebaseWhen": "behind-base-branch",

  "labels": [
    "renovate"
  ],

  "enabledManagers": ["regex"],
  "regexManagers": [
    {
      "description": "Update image versions inside host-specific apps.yml files",
      "fileMatch": [
        "home-lab/inventory/host_vars/[^/]+/apps\\.ya?ml$"
      ],
      "matchStrings": [
        "(?m)^\\s*(?<variableName>\\w+_image):\\s*['\"]?(?<depName>[^:'\"\\s]+):(?<currentValue>[^\"'\\s]+)['\"]?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "description": "Group minor and patch updates per server (apps.yml file)",
      "matchFileNames": ["home-lab/inventory/host_vars/**/apps.yml"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Update applications on {{{packageFile}}}"
    },
    {
      "description": "Automerge minor and patch updates on stable versions (major >= 1)",
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": ">=1.0.0",
      "automerge": true,
      "ignoreTests": true
    },
    {
      "description": "Separate minor updates for pre-1.0.0 versions into individual PRs",
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": "<1.0.0",
      "groupName": null
    },
    {
      "description": "Ensure major updates always create separate PRs",
      "matchUpdateTypes": ["major"],
      "groupName": null
    }
  ]
}
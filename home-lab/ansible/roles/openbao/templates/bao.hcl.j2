ui = {{ openbao_ui | lower }}

storage "raft" {
  path    = "/bao/data"
  node_id = "node1"
}

listener "tcp" {
  address     = "0.0.0.0:8200"
  tls_disable = 1
}

telemetry {
  prometheus_retention_time = "30s"
  disable_hostname = true
}

cluster_addr = "https://{{ ansible_default_ipv4.address }}:8201"
api_addr     = "https://{{ ansible_default_ipv4.address }}:8200"